# =============================================================================
# ShopForge — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit the real .env file to version control.
# =============================================================================

# ---- Application ------------------------------------------------------------
APP_NAME=ShopForge
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- MongoDB ----------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=shopforge

# ---- JWT Authentication -----------------------------------------------------
# IMPORTANT: Generate a strong random key for production.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-generate-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Stripe Payments --------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
